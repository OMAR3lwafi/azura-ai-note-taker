# Supabase Configuration
SUPABASE_URL=http://localhost:54321
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# CORS
CORS_ORIGIN=http://localhost:5173

# LLM Provider (openai or anthropic)
LLM_PROVIDER=openai
LLM_API_KEY=your-llm-api-key

# Embedding Provider (optional, defaults to LLM_API_KEY)
EMBEDDING_PROVIDER=openai
EMBEDDING_API_KEY=your-embedding-api-key
EMBEDDING_MODEL=text-embedding-3-small

# STT Provider Configuration
STT_PROVIDER=deepgram
STT_API_KEY=your-stt-api-key

# 2FA Secret Key (for TOTP encryption)
TOTP_SECRET_KEY=your-secret-key-for-totp-encryption

# KV Store (Upstash Redis or Deno KV)
KV_URL=your-kv-url
KV_TOKEN=your-kv-token

# Upstash Redis (for rate limiting and distributed locks)
UPSTASH_REDIS_REST_URL=https://your-db.upstash.io
UPSTASH_REDIS_REST_TOKEN=your_token_here

# Integration API Keys (optional)
NOTION_CLIENT_ID=your-notion-client-id
NOTION_CLIENT_SECRET=your-notion-client-secret
TRELLO_API_KEY=your-trello-api-key
MS_TODO_CLIENT_ID=your-ms-todo-client-id
MS_TODO_CLIENT_SECRET=your-ms-todo-client-secret

# Sentry Configuration (Error Tracking & Performance Monitoring)
VITE_SENTRY_DSN=https://your-frontend-dsn@sentry.io/project-id
SENTRY_DSN=https://your-backend-dsn@sentry.io/project-id
SENTRY_AUTH_TOKEN=your-sentry-auth-token
ENVIRONMENT=development
